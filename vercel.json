{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "excludeFiles": "{.github/**,data/**,docs/**,models/**,notebooks/**,reports/**,tests/**,**/__pycache__/**,requirements-ml.txt}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
